#!/bin/bash
# Pre-push Hook — current project guardrails.

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
cd "$PROJECT_ROOT" || exit 1

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}[PRE-PUSH] Starting validation before push...${NC}"

# ── P003: Block AI agent pushes ──────────────────────────────────────────────
# Requires SDD_AGENT_MODE to be exactly "true" (case-sensitive).
# Any other value (empty, false, 1) does NOT trigger the block.
if [ "${SDD_AGENT_MODE:-}" = "true" ]; then
    echo -e "${RED}BLOCKED (P003): Agents are not allowed to push.${NC}"
    echo "Policy P003 (Mandatory Human Review) requires all remote updates"
    echo "to be performed by a human."
    echo "FIX: Ask the user to review your changes and run git push manually."
    exit 1
fi

# ── Governance checks via SDD CLI (if available) ───────────────────────────
if command -v uv >/dev/null 2>&1; then
    echo -e "${YELLOW}→ Running governance runtime status...${NC}"
    uv run sdd runtime status
    echo -e "${YELLOW}→ Running governance validation...${NC}"
    uv run sdd governance validate
fi

# ── Project quality gate ────────────────────────────────────────────────────
echo -e "${YELLOW}→ Running make validate...${NC}"
make -C "$PROJECT_ROOT" validate

# ── Summary ──────────────────────────────────────────────────────────────────
BRANCH="$(git rev-parse --abbrev-ref HEAD)"
if git rev-parse --abbrev-ref @{u} >/dev/null 2>&1; then
    COMMIT_COUNT="$(git rev-list --count @{u}..HEAD)"
else
    COMMIT_COUNT="(no upstream set)"
fi

echo -e "${YELLOW}→ Push summary:${NC}"
echo -e "  Branch: $BRANCH"
echo -e "  Commits: $COMMIT_COUNT"
echo -e "  Governance: ${GREEN}✓${NC}"
echo -e "  Validate:   ${GREEN}✓${NC}"
echo -e "${GREEN}[PRE-PUSH] All checks passed. Push allowed.${NC}"
exit 0
