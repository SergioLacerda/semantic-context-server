# Ambiente
ENVIRONMENT=development

# Discord (obrigatório para Interactions)
DISCORD_ENABLE=true # opcional, default: true
DISCORD_PUBLIC_KEY=sua_chave_publica_aqui
DISCORD_APPLICATION_ID=seu_application_id_aqui
DISCORD_TOKEN=seu_bot_token_aqui   # opcional, usado apenas em alguns comandos

# LLM (escolha um)
LLM_PROVIDER=openai          # ou groq, ollama, mock
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-...


# Embeddings (local ou remoto)
EMBEDDING_PROFILE=local
EMBEDDING_PROVIDER=sentence-transformers
DEVICE=cpu                   # ou cuda

# Vector Database
CHROMA_PERSIST_DIR=./data/chroma
